{
  "manifest_version": 3,
  "name": "Mindshift",
  "version": "0.2.0",
  "description": "Save the current page or your bookmarks to your Mindshift knowledge base.",
  "permissions": ["bookmarks", "activeTab", "storage", "tabs", "sidePanel"],
  "host_permissions": ["http://localhost:8001/*", "http://localhost:5173/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Add to Mindshift",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
