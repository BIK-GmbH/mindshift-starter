{
  "manifest_version": 3,
  "name": "Mindshift",
  "version": "0.8.2",
  "description": "Save the current page or your bookmarks to your Mindshift knowledge base.",
  "permissions": ["bookmarks", "activeTab", "storage", "tabs", "sidePanel", "notifications", "contextMenus"],
  "host_permissions": ["http://localhost:8001/*", "http://localhost:5173/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Add to Mindshift",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content/youtube.js"],
      "css": ["content/youtube.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.google.com/search*",
        "*://duckduckgo.com/*"
      ],
      "js": ["content/serp.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "*://*.youtube.com/watch*",
        "*://www.google.com/search*",
        "*://duckduckgo.com/*"
      ],
      "js": ["content/highlight.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "save-current-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Save the current page to Mindshift"
    }
  }
}
