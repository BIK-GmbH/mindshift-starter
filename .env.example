# --- Backend ---
DATABASE_URL=postgresql+psycopg://mindshift:mindshift@localhost:5433/mindshift
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Gemini (used for native-audio podcast generation in card detail)
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview

# GitHub (optional). Without it the GitHub repo importer uses unauthenticated
# requests — fine for development (60 req/h per IP) but tight for production.
# A classic token with public_repo scope is enough; no special permissions.
GITHUB_TOKEN=

# File storage
# `local` writes under STORAGE_PATH. On Railway, mount a volume and set
# STORAGE_PATH to its mount path (e.g. /data). Future backends: `s3`.
STORAGE_BACKEND=local
STORAGE_PATH=./.runtime/storage
# Soft per-user quota (bytes). Default ~2 GiB.
STORAGE_MAX_BYTES_PER_USER=2147483648

# --- Frontend ---
# Empty in local dev (Vite proxies /api → backend). Set to backend URL in production.
VITE_API_BASE_URL=
