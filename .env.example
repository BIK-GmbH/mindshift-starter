# --- Backend ---
DATABASE_URL=postgresql+psycopg://mindshift:mindshift@localhost:5433/mindshift
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Gemini (used for native-audio podcast generation in card detail)
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview

# GitHub (optional). Without it the GitHub repo importer uses unauthenticated
# requests — fine for development (60 req/h per IP) but tight for production.
# A classic token with public_repo scope is enough; no special permissions.
GITHUB_TOKEN=

# YouTube Data API v3 (optional). Powers the "YouTube-Vorschläge" sub-toggle
# in the Related tab and the global Discover page. Without it both surfaces
# show a soft empty state. Get a key at https://console.cloud.google.com →
# APIs & Services → Library → "YouTube Data API v3" → Enable → Credentials.
# Quota: 10 000 units/day free; search.list = 100 units/call. Per-card and
# per-theme results are cached for 24 h.
YOUTUBE_API_KEY=

# YouTube transcript proxy (optional but recommended for production).
# YouTube IP-blocks the timedtext endpoint when too many requests come
# from one source — cloud IPs, VPN exits, and even ordinary home IPs
# after a burst. Pick ONE shape:
#
# (a) Webshare rotating residential pool — recommended. Sign up at
#     webshare.io (1 GB / 10 IPs free), then:
# YOUTUBE_PROXY_USERNAME=
# YOUTUBE_PROXY_PASSWORD=
# YOUTUBE_PROXY_COUNTRIES=de,us       # optional geo-fence
#
# (b) Generic HTTP/SOCKS proxy URL — any provider:
# YOUTUBE_PROXY_URL=http://user:pass@host:port
#
# When neither is set, transcripts fetch direct. yt-dlp is always used
# as a second-attempt fallback when the primary fetch is blocked.

# Supadata.ai (optional, paid-per-call) — last-resort third-party
# transcript provider for situations where every other layer is blocked.
# 100 credits/month free at https://supadata.ai, no card needed.
# 1 transcript = 1 credit. Used only when (1) and (2) both fail.
SUPADATA_API_KEY=

# Symmetric Fernet key for encrypting at-rest MCP server auth tokens.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production. Missing in dev falls back to a key derived
# from JWT_SECRET (warning logged on every boot).
MCP_ENCRYPTION_KEY=

# File storage
# `local` writes under STORAGE_PATH. On Railway, mount a volume and set
# STORAGE_PATH to its mount path (e.g. /data). Future backends: `s3`.
STORAGE_BACKEND=local
STORAGE_PATH=./.runtime/storage
# Soft per-user quota (bytes). Default ~2 GiB.
STORAGE_MAX_BYTES_PER_USER=2147483648

# --- Frontend ---
# Empty in local dev (Vite proxies /api → backend). Set to backend URL in production.
VITE_API_BASE_URL=
